# ScriptCraft Environment Variables Template
# Copy this to .env and fill in your values

# Azure AI Foundry Project Authentication
# Get this from Azure AI Foundry Studio > your project > Settings > Keys and Endpoint
AI_PROJECT_API_KEY=your_ai_project_api_key_here

# Alternative: Service Principal (if API key doesn't work)
# AZURE_CLIENT_ID=your_azure_client_id_here
# AZURE_CLIENT_SECRET=your_azure_client_secret_here  
# AZURE_TENANT_ID=your_azure_tenant_id_here

# Option 3: Managed Identity (For Azure-hosted deployments)
# When running on Azure services, managed identity can be used
# Leave the above variables empty if using this option

# Optional: Custom endpoints (already set to correct value)
AZURE_AI_ENDPOINT=https://linedrive-ai-foundry.services.ai.azure.com/api/projects/linedriveAgents

# Application Configuration
LOG_LEVEL=INFO
DEBUG=false

# Future: Database configuration
# DATABASE_URL=postgresql://user:password@localhost:5432/scriptcraft
